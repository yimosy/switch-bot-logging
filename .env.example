# SwitchBotアプリの「プロフィール > 設定 > 基本データ > アプリバージョンを10回タップ > 開発者向けオプション」で取得
SWITCHBOT_TOKEN=your_token_here
SWITCHBOT_SECRET=your_secret_here

# 取得間隔(秒)。API制限は10,000リクエスト/日なのでデバイス数に応じて調整
POLL_INTERVAL_SECONDS=300

# DB接続先(SQLAlchemy形式)。デフォルトはSQLite
DATABASE_URL=sqlite:////data/switchbot.db
# PostgreSQLの場合:
# DATABASE_URL=postgresql+psycopg2://switchbot:switchbot@db:5432/switchbot

# 記録対象のデバイスタイプ(カンマ区切り)。未指定なら温湿度計系+Hub 2
# TARGET_DEVICE_TYPES=Meter,MeterPlus,MeterPro,MeterPro(CO2),WoIOSensor,Hub 2

# 特定デバイスのみ記録する場合はデバイスIDをカンマ区切りで指定
# TARGET_DEVICE_IDS=
